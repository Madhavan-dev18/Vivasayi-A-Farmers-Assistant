# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# --- Google AI (Gemini, via Genkit) ---
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=

# --- OpenWeatherMap (or your weather provider) ---
# Used server-side only (src/services/weather-service.ts) — never exposed
# to the browser.
WEATHER_API_KEY=

# --- Supabase ---
# Find these in your Supabase project: Settings → API
# NEXT_PUBLIC_ prefixed vars are safe to expose to the browser by design —
# they're the anon/public key, not the service role key. Never put the
# service role key behind a NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
